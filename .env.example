OPENAI_COMPATIBLE_API_KEY=sk-your-api-key
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
OPENAI_COMPATIBLE_MODEL=deepseek-v4-flash

# Optional Doubao Speech Synthesis 2.0 (recommended).
DOUBAO_TTS_API_KEY=
DOUBAO_TTS_BASE_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_SPEAKER=zh_female_vv_uranus_bigtts
# Legacy Volcengine console credentials. Use only when API Key is unavailable.
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=

# Optional OpenAI-compatible /audio/speech provider.
TTS_API_KEY=
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
TTS_INSTRUCTIONS=Speak naturally in a warm, gentle, conversational tone. Use expressive but restrained intonation and clear pauses.

# Optional existing providers
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
NEXT_PUBLIC_USE_MOCK_AVATAR=true
NEXT_PUBLIC_VRM_MODEL_URL=/models/nora.vrm

# Optional additional VRM characters. Put local files in public/models.
NEXT_PUBLIC_VRM_MODEL_NAME_2=
NEXT_PUBLIC_VRM_MODEL_URL_2=
NEXT_PUBLIC_VRM_MODEL_NAME_3=
NEXT_PUBLIC_VRM_MODEL_URL_3=

# Debug controls. Keep false in normal use.
NEXT_PUBLIC_ENABLE_CAMERA_ROTATION=false
# Zoom limit around the initial camera distance. Range: 1.05-3.
NEXT_PUBLIC_CAMERA_ZOOM_RATIO=1.6
NEXT_PUBLIC_ENABLE_CAMERA_PAN=false
NEXT_PUBLIC_ENABLE_POSE_DEBUG=false
NEXT_PUBLIC_ENABLE_MOTION_LIBRARY=false
# Procedural idle/talking motion strength. 0 is almost static, 1 is strongest.
NEXT_PUBLIC_AVATAR_MOTION_INTENSITY=0.45
