# Model and TTS credentials are configured in the browser UI per user/device.
# /api/chat and /api/tts intentionally do not read server-side model or voice keys.
# This keeps public deployments from sharing one backend account with every visitor.

# Optional existing providers
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
NEXT_PUBLIC_USE_MOCK_AVATAR=true
NEXT_PUBLIC_VRM_MODEL_URL=/models/nora.vrm
# Keep this false/empty on Vercel. Serverless file writes are not durable there;
# browser localStorage remains the default conversation persistence layer.
AVATAR_SERVER_CONVERSATION_STORE=false

# Optional additional VRM characters. Put local files in public/models.
NEXT_PUBLIC_VRM_MODEL_NAME_2=
NEXT_PUBLIC_VRM_MODEL_URL_2=
NEXT_PUBLIC_VRM_MODEL_NAME_3=
NEXT_PUBLIC_VRM_MODEL_URL_3=
NEXT_PUBLIC_VRM_MODEL_NAME_4=
NEXT_PUBLIC_VRM_MODEL_URL_4=
NEXT_PUBLIC_VRM_MODEL_NAME_5=
NEXT_PUBLIC_VRM_MODEL_URL_5=
NEXT_PUBLIC_VRM_MODEL_NAME_6=
NEXT_PUBLIC_VRM_MODEL_URL_6=

# Debug controls. Keep false in normal use.
NEXT_PUBLIC_ENABLE_CAMERA_ROTATION=false
# Zoom limit around the initial camera distance. Range: 1.05-3.
NEXT_PUBLIC_CAMERA_ZOOM_RATIO=1.6
NEXT_PUBLIC_ENABLE_CAMERA_PAN=false
NEXT_PUBLIC_ENABLE_POSE_DEBUG=false
NEXT_PUBLIC_ENABLE_MOTION_LIBRARY=false
# Procedural idle/talking motion strength. 0 is almost static, 1 is strongest.
NEXT_PUBLIC_AVATAR_MOTION_INTENSITY=0.45

# Optional VRMA animation clips. Put licensed .vrma files in public/animations.
NEXT_PUBLIC_VRMA_IDLE_URL=
NEXT_PUBLIC_VRMA_LISTENING_URL=
NEXT_PUBLIC_VRMA_THINKING_URL=
NEXT_PUBLIC_VRMA_SPEAKING_URL=
